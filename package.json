{
  "name": "@masterbelt/tree-sitter-masterbelt",
  "version": "0.1.20260611-nightly.112677e",
  "description": "masterbelt grammar for tree-sitter",
  "license": "MIT",
  "repository": "https://github.com/masterbelt/tree-sitter-masterbelt",
  "scripts": {
    "generate": "tree-sitter generate --abi 14",
    "test": "tree-sitter test",
    "parse": "tree-sitter parse",
    "install": "node-gyp-build"
  },
  "devDependencies": {
    "tree-sitter-cli": "0.26.9",
    "prebuildify": "^6.0.1"
  },
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "masterbelt",
    "parser",
    "grammar"
  ],
  "main": "bindings/node",
  "types": "bindings/node",
  "dependencies": {
    "node-addon-api": "^8.2.2",
    "node-gyp-build": "^4.8.2"
  },
  "peerDependencies": {
    "tree-sitter": ">=0.21.1"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "files": [
    "grammar.js",
    "lexical.js",
    "tree-sitter.json",
    "binding.gyp",
    "bindings/node/*",
    "prebuilds/**",
    "queries/*",
    "src/**",
    "*.wasm"
  ],
  "exports": {
    ".": {
      "types": "./bindings/node/index.d.ts",
      "default": "./bindings/node/index.js"
    },
    "./tree-sitter-masterbelt.wasm": "./tree-sitter-masterbelt.wasm",
    "./grammar.js": "./grammar.js",
    "./tree-sitter.json": "./tree-sitter.json",
    "./queries/*": "./queries/*",
    "./src/*": "./src/*",
    "./package.json": "./package.json"
  }
}
